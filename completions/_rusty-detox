#compdef rusty-detox

autoload -U is-at-least

_rusty-detox() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-s+[Sequence to apply (default\: \`default\`)]:NAME:_default' \
'--sequence=[Sequence to apply (default\: \`default\`)]:NAME:_default' \
'-f+[Override config-file resolution with an explicit path]:PATH:_default' \
'--config-file=[Override config-file resolution with an explicit path]:PATH:_default' \
'-n[Dry-run\: plan and report renames without issuing any rename syscalls]' \
'--dry-run[Dry-run\: plan and report renames without issuing any rename syscalls]' \
'-r[Recursive\: descend into directories depth-first leaves-up]' \
'--recursive[Recursive\: descend into directories depth-first leaves-up]' \
'-L[List all loaded sequence names to stdout, one per line]' \
'--list-sequences[List all loaded sequence names to stdout, one per line]' \
'-v[Verbose\: emit one rename line per change to stdout (FR-019)]' \
'--verbose[Verbose\: emit one rename line per change to stdout (FR-019)]' \
'--strict[Activate Strict-compat mode (byte-equal upstream stderr, last-wins flag resolution)]' \
'(--strict)--no-strict[Disable Strict-compat mode even when argv\[0\] or env would activate it]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::paths -- Paths to detox (zero or more):_default' \
":: :_rusty-detox_commands" \
"*::: :->rusty-detox" \
&& ret=0
    case $state in
    (rusty-detox)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rusty-detox-command-$line[2]:"
        case $line[2] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Target shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_rusty-detox__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:rusty-detox-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_rusty-detox_commands] )) ||
_rusty-detox_commands() {
    local commands; commands=(
'completions:Emit a shell-completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'rusty-detox commands' commands "$@"
}
(( $+functions[_rusty-detox__subcmd__completions_commands] )) ||
_rusty-detox__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'rusty-detox completions commands' commands "$@"
}
(( $+functions[_rusty-detox__subcmd__help_commands] )) ||
_rusty-detox__subcmd__help_commands() {
    local commands; commands=(
'completions:Emit a shell-completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'rusty-detox help commands' commands "$@"
}
(( $+functions[_rusty-detox__subcmd__help__subcmd__completions_commands] )) ||
_rusty-detox__subcmd__help__subcmd__completions_commands() {
    local commands; commands=()
    _describe -t commands 'rusty-detox help completions commands' commands "$@"
}
(( $+functions[_rusty-detox__subcmd__help__subcmd__help_commands] )) ||
_rusty-detox__subcmd__help__subcmd__help_commands() {
    local commands; commands=()
    _describe -t commands 'rusty-detox help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_rusty-detox" ]; then
    _rusty-detox "$@"
else
    compdef _rusty-detox rusty-detox
fi
